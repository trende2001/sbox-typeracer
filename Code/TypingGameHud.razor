@using Sandbox;
@using Sandbox.UI;
@using System
@inherits PanelComponent

<root>
	<div class="container">
		<div class="stat">
			<div class="value">@WpmText</div>
			<div class="title">WPM</div>
		</div>
		<div class="stat">
			<div class="value">@CharsText</div>
			<div class="title">CHARACTERS</div>
		</div>
		<div class="stat">
			<div class="value">@TimeText</div>
			<div class="title">TIME</div>
		</div>
	</div>
</root>

@code
{
	private GameManager _gameManager;
	private PlayerState _localPlayer;

	string WpmText => _localPlayer?.WPM.ToString( "F0" ) ?? "--";
	string CharsText => _localPlayer is not null && _gameManager is not null 
		? $"{_localPlayer.CurrentIndex}/{_gameManager.SyncedTargetText?.Length ?? 0}" 
		: "--/--";
	string TimeText => _localPlayer is not null ? $"{_localPlayer.GetElapsedTime():F1}s" : "--s";

	protected override int BuildHash() => HashCode.Combine( WpmText, CharsText, TimeText );

	protected override void OnStart()
	{
		base.OnStart();
		_gameManager = Scene.GetAllComponents<GameManager>().FirstOrDefault();
	}

	protected override void OnUpdate()
	{
		_localPlayer = _gameManager?.GetLocalPlayer();
	}
}
